# =============================================================
# 知识问答系统环境变量配置
# 复制为 .env 后修改
# =============================================================

# ========== Spark 数据处理 ==========
# Spark 应用名称
SPARK_APP_NAME=KnowledgeQA-ETL

# Spark Master 地址（local[*] 表示本地模式）
SPARK_MASTER=local[*]

# 数据目录
UPLOAD_DIR=./data/uploads
PROCESSED_DIR=./data/processed
MILVUS_DB=./data/milvus_lite.db

# ========== Embedding ==========
# Embedding 模型名称
EMBEDDING_MODEL_NAME=all-MiniLM-L6-v2

# Embedding 向量维度
EMBEDDING_DIM=384

# ========== Milvus ==========
# Milvus 集合名称
COLLECTION_NAME=knowledge_base

# 检索返回的 Top-K 文档数
RETRIEVER_TOP_K=5

# 混合检索权重：向量检索权重 vs 关键词检索权重
HYBRID_ALPHA=0.7

# ========== 大语言模型 ==========
# LLM API 基础地址
LLM_API_BASE=https://api.siliconflow.cn/v1

# LLM API Key
LLM_API_KEY=your-api-key-here

# LLM 模型名称
LLM_MODEL_NAME=Qwen/Qwen2.5-7B-Instruct

# LLM 温度参数（0.0-1.0）
LLM_TEMPERATURE=0.3

# LLM 最大输出 token 数
LLM_MAX_TOKENS=2000

# ========== 对话记忆 ==========
# 记忆窗口大小（保留最近 N 轮对话）
MEMORY_WINDOW_SIZE=5

# ========== 文件解析 ==========
# 单文件最大体积（字节）
MAX_FILE_SIZE=52428800

# 允许上传的文件扩展名
ALLOWED_EXTENSIONS=[".txt", ".pdf", ".docx", ".doc", ".md", ".csv"]

# ========== 日志 ==========
LOG_LEVEL=INFO
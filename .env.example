# =============================================================
# 知识问答系统环境变量配置
# 复制为 .env 后修改
# =============================================================

# ========== Spark 数据处理 ==========
# Spark 应用名称
SPARK_APP_NAME=KnowledgeQA-ETL

# Spark Master 地址（local[*] 表示本地模式）
SPARK_MASTER=local[*]

# 管线引擎选择：simple（本地）/ spark（分布式）
PIPELINE_ENGINE=simple

# 最短文本长度过滤（小于此长度的文档将被丢弃）
PIPELINE_MIN_TEXT_LENGTH=50

# ========== 数据库接入 ==========
# 数据库类型：mysql / postgresql / 空表示不启用
DB_TYPE=

# 数据库连接信息
DB_HOST=localhost
DB_PORT=3306
DB_USER=
DB_PASSWORD=
DB_NAME=
DB_TABLE=
DB_TEXT_COLUMNS=title,content  # 逗号分隔的文本列名
DB_QUERY=           # 自定义 SQL 查询（可选）

# 数据目录
UPLOAD_DIR=./data/uploads
PROCESSED_DIR=./data/processed
MILVUS_DB=./data/milvus_lite.db

# ========== Embedding ==========
# 纯文本 Embedding 模型（SiliconFlow）
EMBEDDING_API_KEY=your-api-key-here
EMBEDDING_BASE_URL=https://api.siliconflow.cn/v1
EMBEDDING_MODEL_NAME=BAAI/bge-large-zh-v1.5
EMBEDDING_DIM=1024

# 多模态 Embedding 模型
MULTIMODAL_EMBEDDING_MODEL=Qwen/Qwen3-VL-Embedding-8B
MULTIMODAL_EMBEDDING_DIM=4096
MULTIMODAL_COLLECTION_NAME=knowledge_base_mm

# ========== 大语言模型 ==========
# LLM API 基础地址
LLM_BASE_URL=https://api.siliconflow.cn/v1
LLM_MODEL_NAME=mimo-v2.5
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2048
# LLM API Key
LLM_API_KEY=your-api-key-here

# ========== Milvus ==========
MILVUS_DB_PATH=./data/milvus.db
COLLECTION_NAME=knowledge_base

# ========== 文档切片 ==========
CHUNK_SIZE=500
CHUNK_OVERLAP=50

# ========== 检索配置 ==========
RETRIEVER_TOP_K=5
SIMILARITY_THRESHOLD=0.09

# ========== 服务器 ==========
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO

# LLM 模型名称
LLM_MODEL_NAME=Qwen/Qwen2.5-7B-Instruct

# LLM 温度参数（0.0-1.0）
LLM_TEMPERATURE=0.3

# LLM 最大输出 token 数
LLM_MAX_TOKENS=2000

# ========== 对话记忆 ==========
# 记忆窗口大小（保留最近 N 轮对话）
MEMORY_WINDOW_SIZE=5

# ========== 文件解析 ==========
# 单文件最大体积（字节）
MAX_FILE_SIZE=52428800

# 允许上传的文件扩展名
ALLOWED_EXTENSIONS=[".txt", ".pdf", ".docx", ".doc", ".md", ".csv"]

# ========== 日志 ==========
LOG_LEVEL=INFO